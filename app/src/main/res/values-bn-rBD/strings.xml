    <string name="permission_bluetooth_label">Bluetooth</string>
    <string name="permission_bluetooth_description">এই অ্যাপটির জোড়া করা Bluetooth ডিভাইসগুলিতে সংযোগ করতে \"Bluetooth\" অনুমতি প্রয়োজন।</string>
    <string name="permission_access_fine_location_label">সূক্ষ্ম অবস্থান অ্যাক্সেস</string>
    <string name="permission_access_fine_location_description">CAPod Bluetooth Low Energy ডেটা গ্রহণ করতে \"সূক্ষ্ম অবস্থান\" অনুমতি ব্যবহার করে। আপনার হেডফোন তাদের স্ট্যাটাস সম্প্রচার করতে Bluetooth Low Energy প্রযুক্তি ব্যবহার করে। এই অ্যাপ আপনার অবস্থান নির্ধারণ করতে Bluetooth ডেটা ব্যবহার করবে না।</string>
    <string name="permission_background_location_label">ব্যাকগ্রাউন্ড অবস্থান অ্যাক্সেস</string>
    <string name="permission_background_location_description">CAPod \"ব্যাকগ্রাউন্ড অবস্থান অ্যাক্সেস\" ব্যবহার করে অ্যাপ বন্ধ থাকাকালীন \"পপআপ দেখান\" এবং \"অটোকানেক্ট\" এর মতো বৈশিষ্ট্যগুলি সক্ষম করতে। ব্যাকগ্রাউন্ড অবস্থান অ্যাক্সেস অ্যাপটিকে ব্যাকগ্রাউন্ডে থাকাকালীন Bluetooth Low Energy ডেটা গ্রহণ করতে দেয়। এই অ্যাপ আপনার অবস্থান নির্ধারণ করতে Bluetooth ডেটা ব্যবহার করবে না।</string>
