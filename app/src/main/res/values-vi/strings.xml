    <string name="permission_bluetooth_scan_label">Quét Bluetooth</string>
    <string name="permission_bluetooth_scan_description">Quyền Bluetooth scanning cho phép ứng dụng này khám phá và nhận dữ liệu Bluetooth từ các thiết bị ở gần như AirPods của bạn.</string>
