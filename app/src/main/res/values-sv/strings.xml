    <string name="permission_access_fine_location_label">Exakt plats</string>
    <string name="permission_access_fine_location_description">CAPod använder behörigheten \"exakt plats\" för att ta emot Bluetooth Low Energy-data. Dina hörlurar använder Bluetooth Low Energy-teknik för att sända sin status. Denna app kommer INTE att använda Bluetooth-data för att bestämma din plats.</string>
    <string name="permission_background_location_label">Platsåtkomst i bakgrunden</string>
    <string name="permission_background_location_description">CAPod använder \"platsåtkomst i bakgrunden\" för att aktivera funktioner som \"Visa popup\" och \"Anslut automatiskt\" medan appen är stängd. Platsåtkomst i bakgrunden tillåter appen att ta emot Bluetooth Low Energy-data medan den körs i bakgrunden. Denna app kommer INTE att använda Bluetooth-data för att bestämma din plats.</string>
