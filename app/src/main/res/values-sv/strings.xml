    <string name="permission_bluetooth_connect_label">Bluetooth-anslutning</string>
    <string name="permission_bluetooth_connect_description">Denna app kräver behörigheten \"Bluetooth-anslutning\" för att interagera med parkopplade enheter och initiera anslutningar.</string>
    <string name="permission_bluetooth_scan_label">Bluetooth-skanning</string>
    <string name="permission_bluetooth_scan_description">Behörigheten \"Bluetooth-skanning\" tillåter denna app att upptäcka och ta emot Bluetooth-data från enheter i närheten, som dina AirPods.</string>
    <string name="permission_bluetooth_label">Bluetooth</string>
