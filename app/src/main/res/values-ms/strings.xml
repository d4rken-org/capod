    <string name="permission_bluetooth_connect_label">Sambungan Bluetooth</string>
    <string name="permission_bluetooth_connect_description">Apl ini memerlukan kebenaran \"Sambungan Bluetooth\" untuk berinteraksi dengan peranti yang digandingkan dan memulakan sambungan.</string>
