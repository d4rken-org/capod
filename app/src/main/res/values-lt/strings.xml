    <string name="permission_bluetooth_connect_description">Šiai programai reikalingas „Bluetooth prisijungimo\" leidimas, kad galėtų sąveikauti su susietais įrenginiais ir inicijuoti ryšius.</string>
    <string name="permission_bluetooth_scan_label">„Bluetooth\" skenavimas</string>
    <string name="permission_bluetooth_scan_description">„Bluetooth skenavimo\" leidimas leidžia šiai programai aptikti ir gauti „Bluetooth\" duomenis iš netoliese esančių įrenginių, tokių kaip jūsų „AirPods\".</string>
    <string name="permission_bluetooth_label">Bluetooth</string>
    <string name="permission_bluetooth_description">Šiai programai reikalingas „Bluetooth\" leidimas, kad galėtų prisijungti prie susietų „Bluetooth\" įrenginių.</string>
    <string name="permission_access_fine_location_label">Prieiga prie tikslios vietos</string>
    <string name="permission_access_fine_location_description">CAPod naudoja „tikslios vietos\" leidimą „Bluetooth Low Energy\" duomenims gauti. Jūsų ausinės naudoja „Bluetooth Low Energy\" technologiją savo būsenai transliuoti. Ši programa NENAUDOS „Bluetooth\" duomenų jūsų vietai nustatyti.</string>
    <string name="permission_background_location_label">Foninė prieiga prie vietos</string>
    <string name="permission_background_location_description">CAPod naudoja „foninę prieigą prie vietos\", kad įjungtų tokias funkcijas kaip „Rodyti iškylantįjį langą\" ir „Automatinis prisijungimas\", kai programa uždaryta. Foninė prieiga prie vietos leidžia programai gauti „Bluetooth Low Energy\" duomenis fone. Ši programa NENAUDOS „Bluetooth\" duomenų jūsų vietai nustatyti.</string>
