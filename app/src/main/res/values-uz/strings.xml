    <string name="permission_bluetooth_connect_label">Bluetooth ulanish</string>
    <string name="permission_bluetooth_connect_description">Ushbu ilova juftlangan qurilmalar bilan o\'zaro aloqa qilish va ulanishlarni boshlash uchun \"Bluetooth ulanish\" ruxsatini talab qiladi.</string>
    <string name="permission_bluetooth_scan_label">Bluetooth skanerlash</string>
    <string name="permission_bluetooth_scan_description">\"Bluetooth skanerlash\" ruxsati ushbu ilovaga yaqin atrofdagi qurilmalardan, masalan, AirPods\'dan Bluetooth ma\'lumotlarini aniqlash va qabul qilish imkonini beradi.</string>
    <string name="permission_bluetooth_label">Bluetooth</string>
    <string name="permission_bluetooth_description">Ushbu ilova juftlangan Bluetooth qurilmalariga ulanish uchun \"Bluetooth\" ruxsatini talab qiladi.</string>
    <string name="permission_access_fine_location_label">Aniq joylashuvga kirish</string>
    <string name="permission_access_fine_location_description">CAPod Bluetooth Low Energy ma\'lumotlarini qabul qilish uchun \"aniq joylashuv\" ruxsatidan foydalanadi. Naushniklaringiz o\'z holatini uzatish uchun Bluetooth Low Energy texnologiyasidan foydalanadi. Ushbu ilova joylashuvingizni aniqlash uchun Bluetooth ma\'lumotlaridan FOYDALANMAYDI.</string>
    <string name="permission_background_location_label">Fon joylashuviga kirish</string>
    <string name="permission_background_location_description">CAPod ilova yopilganda \"Qalqib chiquvchi oynani ko\'rsatish\" va \"Avtomatik ulanish\" kabi funktsiyalarni yoqish uchun \"fon joylashuviga kirish\" dan foydalanadi. Fon joylashuviga kirish ilovaga fonda ishlayotganda Bluetooth Low Energy ma\'lumotlarini qabul qilish imkonini beradi. Ushbu ilova joylashuvingizni aniqlash uchun Bluetooth ma\'lumotlaridan FOYDALANMAYDI.</string>
    <string name="permission_ignore_battery_optimizations_label">Batareya optimallashtirishlarini o\'chirish</string>
    <string name="permission_ignore_battery_optimizations_description">Batareya optimallashtirishlari ilova fonda ishlayotganda Bluetooth ma\'lumotlarini ishonchli qabul qilishiga to\'sqinlik qiladi.</string>
