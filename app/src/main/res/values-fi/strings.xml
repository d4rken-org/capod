    <string name="permission_bluetooth_scan_description">\"Bluetooth-skannaus\" -lupa antaa tämän sovelluksen löytää ja vastaanottaa Bluetooth-tietoja lähellä olevista laitteista, kuten AirPodeistasi.</string>
