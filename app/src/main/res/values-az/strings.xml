    <string name="permission_bluetooth_scan_description">\"Bluetooth skaneri\" icazəsi bu tətbiqə AirPods kimi yaxınlıqdakı cihazlardan Bluetooth məlumatlarını kəşf etməyə və almağa imkan verir.</string>
    <string name="permission_bluetooth_label">Bluetooth</string>
    <string name="permission_bluetooth_description">Bu tətbiq cütləşdirilmiş Bluetooth cihazlarına qoşulmaq üçün \"Bluetooth\" icazəsini tələb edir.</string>
    <string name="permission_access_fine_location_label">Dəqiq məkan</string>
