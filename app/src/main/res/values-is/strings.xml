    <string name="permission_bluetooth_scan_label">Bluetooth skönnun</string>
    <string name="permission_bluetooth_scan_description">\"Bluetooth skönnunar\" heimildin gerir þessu forriti kleift að uppgötva og taka á móti Bluetooth gögnum frá nálægum tækjum eins og AirPods.</string>
