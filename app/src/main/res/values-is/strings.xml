    <string name="permission_bluetooth_description">Þetta forrit þarfnast \"Bluetooth\" heimild til að tengjast pöruðum Bluetooth tækjum.</string>
    <string name="permission_access_fine_location_label">Nákvæm staðsetning</string>
    <string name="permission_access_fine_location_description">CAPod notar \"nákvæma staðsetningu\" heimild til að taka á móti Bluetooth Low Energy gögnum. Heyrnartólin þín nota Bluetooth Low Energy tækni til að senda út stöðu sína. Þetta forrit mun EKKI nota Bluetooth gögn til að ákvarða staðsetningu þína.</string>
    <string name="permission_background_location_label">Bakgrunns staðsetningaraðgangur</string>
