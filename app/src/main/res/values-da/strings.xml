    <string name="permission_bluetooth_connect_label">Bluetooth-forbindelse</string>
    <string name="permission_bluetooth_connect_description">Denne app kræver tilladelsen \"Bluetooth-forbindelse\" for at interagere med parrede enheder og starte forbindelser.</string>
    <string name="permission_bluetooth_scan_label">Bluetooth-scanning</string>
    <string name="permission_bluetooth_scan_description">Tilladelsen \"Bluetooth-scanning\" gør det muligt for denne app at opdage og modtage Bluetooth-data fra enheder i nærheden, f.eks. dine AirPods.</string>
    <string name="permission_bluetooth_label">Bluetooth</string>
    <string name="permission_bluetooth_description">Denne app kræver \"Bluetooth\"-tilladelsen for at oprette forbindelse til parrede Bluetooth-enheder.</string>
    <string name="permission_access_fine_location_label">Adgang til præcis placering</string>
    <string name="permission_access_fine_location_description">CAPod bruger tilladelsen \"præcis placering\" til at modtage Bluetooth Low Energy-data. Dine hovedtelefoner bruger Bluetooth Low Energy-teknologi til at udsende deres status. Denne app vil IKKE bruge Bluetooth-data til at bestemme din placering.</string>
    <string name="permission_background_location_label">Baggrundsplaceringsadgang</string>
    <string name="permission_background_location_description">CAPod bruger \"baggrundsplaceringsadgang\" til at aktivere funktioner som \"Vis pop op\" og \"Auto-tilslut\", mens appen er lukket. Baggrundsplaceringsadgang gør det muligt for appen at modtage Bluetooth Low Energy-data, mens den er i baggrunden. Denne app vil IKKE bruge Bluetooth-data til at bestemme din placering.</string>
