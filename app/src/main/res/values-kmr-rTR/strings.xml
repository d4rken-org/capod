    <string name="permission_bluetooth_scan_label">Lêgerîna Bluetooth</string>
    <string name="permission_bluetooth_scan_description">Destûra \"Lêgerîna Bluetooth\" dihêle ku ev sepan amûrên nêzîk ên wekî AirPods-ên we bibîne û daneyên Bluetooth ji wan bistîne.</string>
