    <string name="permission_bluetooth_connect_label">Bluetooth დაკავშირება</string>
    <string name="permission_bluetooth_connect_description">ამ აპს სჭირდება \"Bluetooth connect\" ნებართვა, რომ დაწყვილებულ მოწყობილობებთან იმუშაოს და კავშირები დაიწყოს.</string>
    <string name="permission_bluetooth_scan_label">Bluetooth სკანირება</string>
    <string name="permission_bluetooth_scan_description">\"Bluetooth scanning\" ნებართვა ამ აპს საშუალებას აძლევს, აღმოაჩინოს და მიიღოს Bluetooth მონაცემები ახლომდებარე მოწყობილობებიდან, მაგალითად თქვენი AirPods-იდან.</string>
    <string name="permission_bluetooth_label">Bluetooth</string>
    <string name="permission_bluetooth_description">ამ აპს სჭირდება \"Bluetooth\" ნებართვა დაწყვილებულ Bluetooth მოწყობილობებთან დასაკავშირებლად.</string>
    <string name="permission_access_fine_location_label">ზუსტი მდებარეობის წვდომა</string>
    <string name="permission_access_fine_location_description">CAPod იყენებს \"fine location\" ნებართვას Bluetooth Low Energy მონაცემების მისაღებად. თქვენი ყურსასმენები Bluetooth Low Energy ტექნოლოგიას იყენებს საკუთარი სტატუსის გადასაცემად. ეს აპი Bluetooth მონაცემებს თქვენი მდებარეობის დასადგენად არ გამოიყენებს.</string>
    <string name="permission_background_location_label">ფონური მდებარეობის წვდომა</string>
    <string name="permission_background_location_description">CAPod იყენებს \"background location access\"-ს, რათა \"Show popup\" და \"AutoConnect\" ფუნქციები იმუშაოს მაშინაც, როცა აპი დახურულია. ფონური მდებარეობის წვდომა აპს საშუალებას აძლევს, Bluetooth Low Energy მონაცემები ფონურ რეჟიმში მიიღოს. ეს აპი Bluetooth მონაცემებს თქვენი მდებარეობის დასადგენად არ გამოიყენებს.</string>
