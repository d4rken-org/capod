    <string name="profiles_signal_quality_max_label">கடுமையான</string>
    <string name="profiles_priority_hint">சுயவிவர வரிசை முன்னுரிமையை தீர்மானிக்கிறது. சுயவிவரங்களை மறுவரிசைப்படுத்த இழுக்கவும் — பட்டியலில் உயர்ந்த சுயவிவரங்கள் பல சாதனங்கள் பொருந்தும்போது முன்னுரிமை பெறும்.</string>
