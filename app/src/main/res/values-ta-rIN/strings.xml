    <string name="upgrade_capod_label">CAPod ஐ மேம்படுத்து</string>
    <string name="upgrade_capod_description">கூடுதல் அம்சங்களைப் பெற்று டெவலப்பரை ஆதரிக்கவும்.</string>
    <string name="upgrade_preamble">CAPod ஒரு நபரால் உருவாக்கப்பட்டது. மேம்படுத்துவது கூடுதல் அம்சங்களை திறக்கிறது மற்றும் பயன்பாட்டை உயிருடன் வைத்திருக்க உதவுகிறது.</string>
    <string name="upgrade_benefit_themes">தீம் தனிப்பயனாக்கம்</string>
    <string name="upgrade_benefit_autoplay">தானியங்கு இயக்கம் மற்றும் தானியங்கு இடைநிறுத்தம்</string>
    <string name="upgrade_benefit_autoconnect">தானியங்கு இணைப்பு</string>
    <string name="upgrade_benefit_popups">கேஸ் திறக்கும்போது மற்றும் இணைப்பின்போது பாப்அப்</string>
    <string name="upgrade_benefit_widgets">முகப்புத் திரை விட்ஜெட்கள்</string>
    <string name="upgrade_benefit_device_settings">மேம்பட்ட சாதன அமைப்புகள்</string>
    <string name="upgrade_benefit_device_controls">சாதன கட்டுப்பாடுகள் — இரைச்சல், ஸ்டெம்கள் மற்றும் மேலும்</string>
    <string name="upgrade_benefit_support">டெவலப்பரை ஆதரிக்கவும்</string>
    <string name="upgrade_benefit_disclaimer">அம்சங்களின் கிடைக்கும் தன்மை உங்கள் ஹெட்ஃபோன்கள் மற்றும் சாதனத்தை சார்ந்துள்ளது.</string>
    <string name="upgrade_screen_options_description">ஒரே அம்சங்கள், வேறுபட்ட விலை. சந்தா இலவச சோதனையை உள்ளடக்கியது மற்றும் எந்த நேரத்திலும் ரத்து செய்யலாம்.</string>
    <string name="upgrade_screen_subscription_trial_action">இலவச சோதனையை தொடங்கவும்</string>
    <string name="upgrade_screen_subscription_action">ஆண்டுதோறும் சந்தா செலுத்தவும்</string>
    <string name="upgrade_screen_subscription_action_hint">%s/ஆண்டு</string>
    <string name="upgrade_screen_iap_action">ஒரு முறை வாங்கவும்</string>
    <string name="upgrade_screen_iap_action_hint">ஒரு முறை வாங்குதல்: %s</string>
    <string name="upgrade_screen_restore_purchase_action">வாங்குதலை மீட்டமை</string>
    <string name="upgrade_screen_restore_purchase_message">வாங்குதல்கள் எதுவும் இல்லை. நீங்கள் சரியான கணக்கைப் பயன்படுத்துகிறீர்களா?</string>
    <string name="upgrade_screen_restore_troubleshooting_msg">நீங்கள் சமீபத்தில் வாங்கியிருந்தால், Google Play ஒத்திசைக்க சிறிது நேரம் ஆகலாம்.</string>
    <string name="upgrade_screen_restore_sync_patience_hint">உங்கள் கொள்முதல் தோன்றவில்லை என்றால் சில நிமிடங்களில் மீண்டும் முயற்சிக்கவும்.</string>
    <string name="upgrade_screen_restore_multiaccount_hint">கொள்முதலுக்கு பயன்படுத்திய அதே Google கணக்கில் நீங்கள் உள்நுழைந்திருக்கிறீர்கள் என்பதை உறுதிசெய்யவும்.</string>
    <string name="settings_monitor_mode_label">கண்காணிப்பு முறை</string>
    <string name="settings_monitor_mode_description">இந்த ஆப்ஸ் எந்தச் சூழ்நிலைகளில் புளூடூத் தரவைக் கண்காணிக்கிறது.</string>
    <string name="settings_monitor_connected_notification_label">கூடுதல் அறிவிப்பு</string>
    <string name="settings_monitor_connected_notification_description">ஒரு சாதனம் இணைக்கப்படும்போது கூடுதல் அறிவிப்பைக் காட்டுகிறது. \"சாதன நிலை\" சேனலை முடக்குவதன் மூலம் நிரந்தர \"சாதனங்கள் இல்லை\" அறிவிப்பை மறைக்க இது உங்களை அனுமதிக்கிறது.</string>
    <string name="settings_keep_notification_after_disconnect_label">துண்டிக்கப்பட்ட பிறகு அறிவிப்பை வைத்திரு</string>
    <string name="settings_keep_notification_after_disconnect_description">உங்கள் AirPods துண்டிக்கப்பட்ட பிறகும் கடைசியாக அறியப்பட்ட பேட்டரி நிலைகளைக் காட்டவும்</string>
    <string name="settings_scanner_mode_label">ஸ்கேனர் முறை</string>
    <string name="settings_scanner_mode_description">புளூடூத் குறைந்த ஆற்றல் தரவு ஸ்கேனர் செயல்திறனுக்கு முன்னுரிமை அளிக்க வேண்டுமா அல்லது ஆற்றலைச் சேமிக்க வேண்டுமா?</string>
    <string name="settings_autopause_label">தானியங்கு இடைநிறுத்தம்</string>
    <string name="settings_autopause_description">உங்கள் காதில் இருந்து சாதனத்தை அகற்றும்போது ஆடியோவை இடைநிறுத்தவும்.</string>
    <string name="settings_autopplay_label">தானியங்கு இயக்கம்</string>
    <string name="settings_autoplay_description">சாதனம் அணியும்போது ஆடியோ இயக்கத்தைத் தொடங்கு.</string>
    <string name="settings_eardetection_info_label">காது கண்டறிதல் குறிப்பு</string>
    <string name="settings_eardetection_info_description">காது கண்டறிதல் ஒரு பாட்க்கு மட்டுமே வேலை செய்தால், இது Apple வரம்பு. \"முதன்மை பாட்\" (ஒலிபெருக்கிக்கு பயன்படுத்தப்படும்) மட்டுமே கண்டறியப்படும். Apple சாதனங்களில் அமைக்கவும்: அமைப்புகள் → புளூடூத் → AirPods → ஒலிபெருக்கி.</string>
    <string name="settings_fake_data_label">போலித் தரவு</string>
    <string name="settings_fake_data_description">போலித் தரவைக் காட்டு, அதாவது இல்லாத சாதனங்களைப் போலியாக உருவாக்கு.</string>
    <string name="settings_debug_label">பிழைத்திருத்த அமைப்புகள்</string>
    <string name="settings_debug_description">ஆப்ஸில் உள்ள சிக்கல்களைச் சரிசெய்ய உதவும் கூடுதல் அமைப்புகள்.</string>
    <string name="settings_signal_minimum_label">குறைந்தபட்ச சிக்னல் தரம்</string>
    <string name="settings_signal_minimum_description">ஒரு சாதனம் உங்களுடையதாகக் கருதப்படுவதற்குத் தேவையான குறைந்தபட்ச சிக்னல் தரம்.</string>
    <string name="settings_autoconnect_label">தானியங்கு இணைப்பு</string>
    <string name="settings_autoconnect_description">ஆண்ட்ராய்டு தானாக இணைக்கவில்லை என்றால், நாமும் அதைக் கேட்கலாம். இது கண்காணிப்பு முறை அமைப்பை \'எப்போதும்\' என அமைக்கும். புதிய ஆண்ட்ராய்டு பதிப்புகளில் வேலை செய்யாமல் போகலாம்.</string>
    <string name="settings_autoconnect_condition_label">தானியங்கு இணைப்பு நிபந்தனை</string>
    <string name="settings_autoconnect_condition_description">உங்கள் சாதனத்துடன் எப்போது இணைக்க முயற்சிக்க வேண்டும்?</string>
    <string name="settings_devices_label">சாதனங்கள்</string>
    <string name="settings_devices_description">உங்கள் சாதனங்களை நிர்வகிக்கவும்.</string>
    <string name="settings_reaction_label">எதிர்வினைகள்</string>
    <string name="settings_reaction_description">நிகழ்வுகள் மற்றும் நடத்தைகளுக்கு எதிர்வினையாற்று.</string>
    <string name="settings_category_yourdevice_label">உங்கள் சாதனம்</string>
    <string name="settings_category_compatibility_options_title">இணக்கத்தன்மை விருப்பங்கள்</string>
    <string name="settings_category_compatibility_options_description">எல்லாம் வேலை செய்தால் தொடாதே ;)</string>
    <string name="settings_compat_offloaded_filtering_disabled_title">வன்பொருள் வடிகட்டலை முடக்கு</string>
    <string name="settings_compat_offloaded_filtering_disabled_summary">கணினிக்கு தரவு வடிகட்டலை ஒப்படைக்காதீர், பதிலாக எல்லா தரவையும் பெற்று ஆப்ஸிலேயே வடிகட்டு.</string>
    <string name="settings_compat_offloaded_batching_disabled_title">வன்பொருள் தொகுதிப்படுத்தலை முடக்கு</string>
    <string name="settings_compat_offloaded_batching_disabled_summary">சேகரிக்கப்பட்ட BLE தரவை எங்களுக்கு அனுப்புவதற்கு முன்பு கணினி குழுவாக்க அனுமதிக்காதீர்கள்.</string>
    <string name="settings_onepod_mode_label">ஒரு பாட் முறை</string>
    <string name="settings_onepod_mode_description">இரண்டு பாட்களையும் அணிய வேண்டிய அவசியமில்லை, எதிர்வினைகளைத் தூண்டுவதற்கு ஒரு பாட் அணிந்தால் போதும்.</string>
    <string name="settings_popup_caseopen_label">கேஸ் பாப்அப்பைக் காட்டு</string>
    <string name="settings_popup_caseopen_description">சாதனத்தின் கேஸ் திறக்கப்படும்போது ஒரு பாப்அப்பைக் காட்டு (சோதனை).</string>
    <string name="settings_popup_connected_label">இணைப்பு பாப்அப்பைக் காட்டு</string>
    <string name="settings_popup_connected_description">சாதனம் முதல் முறையாக இணைக்கப்படும்போது ஒரு பாப்அப்பைக் காட்டு.</string>
    <string name="notification_channel_device_status_label">சாதன நிலை</string>
    <string name="notification_channel_device_status_connected_label">இணைக்கப்பட்ட சாதனம்</string>
    <string name="monitor_notification_extra_enabled_hint">கணினி அமைப்புகளில் இந்த அறிவிப்பை முடக்கலாம்.</string>
    <string name="support_debuglog_label">பிழைத்திருத்த பதிவு</string>
    <string name="support_debuglog_desc">ஆப்ஸ் செய்யும் அனைத்தையும் நீங்கள் பகிரக்கூடிய ஒரு உரைக் கோப்பில் பதிவுசெய்க.</string>
    <string name="debug_debuglog_size_label">அளவு</string>
    <string name="debug_debuglog_size_compressed_label">சுருக்கப்பட்ட அளவு</string>
    <string name="debug_notification_channel_label">பிழைத்திருத்த அறிவிப்புகள்</string>
    <string name="debug_debuglog_file_label">பதிவுசெய்யப்பட்ட பதிவு கோப்பு</string>
    <string name="debug_debuglog_recording_progress">பிழைத்திருத்த பதிவைப் பதிவுசெய்கிறது</string>
    <string name="debug_debuglog_record_action">பிழைத்திருத்த பதிவைப் பதிவுசெய்</string>
    <string name="debug_debuglog_stop_action">பதிவை நிறுத்து</string>
    <string name="debug_debuglog_sensitive_information_message">உருவாக்கப்பட்ட கோப்பில் முக்கியமான தகவல்கள் உள்ளன (எ.கா. புளூடூத் சாதன விவரங்கள்). நம்பகமான தரப்பினருடன் மட்டுமே பகிரவும்.</string>
    <string name="settings_debuglog_explanation">இந்த அம்சம் ஆப்ஸ் செய்யும் அனைத்தையும் பகிரக்கூடிய கோப்பில் பதிவுசெய்கிறது. உருவாக்கப்பட்ட கோப்பில் முக்கியமான தகவல்கள் உள்ளன (எ.கா. புளூடூத் சாதன விவரங்கள்). நம்பகமான தரப்பினருடன் மட்டுமே பகிரவும் (எ.கா. ஒரு சிக்கலைச் சரிசெய்யும் டெவலப்பர்).</string>
    <string name="settings_support_installid_label">நிறுவல் ஐடி</string>
    <string name="settings_support_installid_desc">தானியங்கி பிழை அறிக்கைகள் அநாமதேயமானவை. டெவலப்பர் உங்கள் பிழை அறிக்கைகளைக் கண்டுபிடிக்க வேண்டும் என்றால் உங்கள் நிறுவல் ஐடியைப் பகிரவும்.</string>
    <string name="settings_support_label">ஆதரவு</string>
    <string name="settings_support_description">உங்களுக்கு உதவி தேவைப்பட்டால்.</string>
    <string name="settings_wiki_label">விக்கி</string>
    <string name="settings_wiki_description">அடிக்கடி கேட்கப்படும் கேள்விகள் &amp; வழிகாட்டிகள்</string>
    <string name="issue_tracker_label">சிக்கல் கண்காணிப்பான்</string>
    <string name="issue_tracker_description">பிழை அறிக்கைகள் மற்றும் அம்சக் கோரிக்கைகளுக்கான பொது சிக்கல் கண்காணிப்பான் (ஆங்கிலம் மட்டும்).</string>
    <string name="discord_label">டிஸ்கார்ட்</string>
